# ============================================
# 智能文档检索助手 - 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================

# --- DeepSeek API（必填）---
LLM_API_KEY=your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60

# --- 文档切块参数 ---
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50

# --- 检索参数 ---
RAG_TOP_K=5
RAG_DEFAULT_MAX_HOPS=2
RAG_RERANK_TOP_K=3

# --- 日志 ---
RAG_LOG_LEVEL=INFO
